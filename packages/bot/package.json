{
  "name": "@rpg/bot",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../game-core/prisma/schema.prisma",
    "db:push": "prisma db push --schema=../game-core/prisma/schema.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@game/core": "workspace:*",
    "@napi-rs/canvas": "^0.1.97",
    "@prisma/client": "^6.6.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "better-sqlite3": "^11.8.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
