{
  "name": "discord-rpg-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Discord RPG bot with game-core, bot, and web apps",
  "scripts": {
    "build": "pnpm -r --filter=!apps/web run build",
    "dev:bot": "pnpm --filter @rpg/bot dev",
    "dev:web": "pnpm --filter @rpg/web dev",
    "prisma:generate": "pnpm -r --filter=@game/core run prisma:generate",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "better-sqlite3": "^11.10.0",
    "sql.js": "^1.14.1"
  }
}
